@"
# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# LNbits
LNBITS_URL=http://your-lnbits-instance:5000
LNBITS_MAIN_INVOICE_KEY=your_main_invoice_key_here
LNBITS_MAIN_ADMIN_KEY=your_main_admin_key_here
LNBITS_PAYOUT_ADMIN_KEY=your_payout_admin_key_here
LNBITS_PROFIT_ADMIN_KEY=your_profit_admin_key_here

# Game config
PAYMENT_AMOUNT_SATS=21
FIRST_PLAY_BONUS_SATS=11

# Admin
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Mempool
MEMPOOL_API_URL=http://localhost:8081

# Web server
PORT=3002

# Cards directory (for bot animation)
CARDS_DIR=/home/nrfm/BitcoinTarotBot/cards
"@ | Out-File -FilePath .env.example -Encoding utf8